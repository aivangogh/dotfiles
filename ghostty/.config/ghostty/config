theme = Ayu

background = #0b0e14

font-family = FiraCode Nerd Font
font-size = 10
cursor-style = block
mouse-hide-while-typing = true
gtk-titlebar = false
window-height = 40
window-width = 135
window-padding-x = 6,6
window-padding-y = 6,6
window-padding-balance = true
window-save-state = always
shell-integration = none
title = " "

keybind = shift+enter=text:\n
